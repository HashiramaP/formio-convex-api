# convex-api environment files (all gitignored except this example).
#
# Three deploy targets — see README "Environments":
#   .env.local    dev      — your personal Convex Cloud dev deployment (project: formio-db)
#   .env.staging  staging  — shared Convex Cloud "staging" deployment (project: formio-db)
#   .env.prod     prod     — self-hosted Convex backend (Canada)
#
# ── dev (.env.local) ────────────────────────────────────────────────
# Managed by `npx convex dev` after `npx convex login`. It writes:
#   CONVEX_DEPLOYMENT=dev:<your-dev-deployment>
# No manual secrets needed. Do NOT set CONVEX_SELF_HOSTED_* here anymore.
#
# ── staging (.env.staging) ──────────────────────────────────────────
# Targets the cloud "staging" deployment. REQUIRED: a deploy key minted
# from that deployment (Dashboard → formio-db → staging → Deploy keys).
# Without it, `convex deploy` falls back to the reserved default prod
# deployment, so `deploy:staging` / `gen:api:staging` refuse to run.
CONVEX_DEPLOY_KEY=''
# Optional (only for scripts that read the staging URL directly):
# CONVEX_URL='https://<staging>.convex.cloud'
# CONVEX_SITE_URL='https://<staging>.convex.site'
#
# ── prod (.env.prod) ────────────────────────────────────────────────
# Self-hosted backend (provisioned via infra/convex Pulumi stack).
CONVEX_SELF_HOSTED_URL=''
CONVEX_SELF_HOSTED_ADMIN_KEY=''
